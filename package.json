{
  "name": "osm-indoor",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "dev:leaflet": "pnpm --filter @osminedit-lib/example-leaflet dev",
    "dev:maplibre": "pnpm --filter @osminedit-lib/example-maplibre dev",
    "build:examples": "pnpm --filter @osminedit-lib/example-vanilla build && pnpm --filter @osminedit-lib/example-leaflet build && pnpm --filter @osminedit-lib/example-maplibre build",
    "test:e2e": "pnpm test:e2e:leaflet && pnpm test:e2e:maplibre",
    "test:e2e:leaflet": "playwright test tests/e2e/leaflet-example.spec.ts --project=leaflet",
    "test:e2e:maplibre": "playwright test tests/e2e/maplibre-example.spec.ts --project=maplibre"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/leaflet": "^1.9.21",
    "happy-dom": "^20.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
